{
  "title": "PMS System Overview",
  "uid": "pms-system-overview",
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "graph",
      "targets": [{
        "expr": "rate(http_server_requests_seconds_count{application=~\"service\"}[1m]",
        "legendFormat": "{{application}}"
      }]
    }
  ],
  "templating": {
    "list": [{
      "name": "service",
      "type": "query",
      "query": "label_values(up, application)"
    }]
  }
}